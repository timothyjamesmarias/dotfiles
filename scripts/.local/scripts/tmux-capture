#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: tmux-capture [-a] [-p] [-t pane_id]
  -a    Capture full scrollback (default: visible pane only)
  -p    Print to stdout instead of opening in \$EDITOR
  -t    Target pane ID (default: current pane)
EOF
}

all=false
pipe=false
target=""

while getopts "apt:h" opt; do
  case "$opt" in
    a) all=true ;;
    p) pipe=true ;;
    t) target="$OPTARG" ;;
    h) usage; exit 0 ;;
    *) usage; exit 1 ;;
  esac
done

# Build capture command
capture_args=(-p)
if $all; then
  capture_args+=(-S -)
fi
if [[ -n "$target" ]]; then
  capture_args+=(-t "$target")
fi

content=$(tmux capture-pane "${capture_args[@]}" 2>&1) || {
  echo "tmux-capture: failed to capture pane" >&2
  exit 1
}

if $pipe; then
  printf '%s\n' "$content"
  exit 0
fi

tmpfile=$(mktemp /tmp/tmux-capture.XXXXXX)
printf '%s\n' "$content" > "$tmpfile"

editor="${EDITOR:-nvim}"
tmux new-window "zsh -lc '${editor} ${tmpfile}; rm -f ${tmpfile}'"
