map <Leader>dd <Action>(ActivateDatabaseToolWindow)
map <Leader>do <Action>(Console.Jdbc.ChooseSchema)
map <Leader>dq <Action>(CloseContent)
map <Leader>df <Action>(ReformatCode)

let g:WhichKeyDesc_db_connect = '<leader>dc Connect'
let g:WhichKeyDesc_db_console = '<leader>dC New console'
let g:WhichKeyDesc_db_eval = '<leader>de Execute query'
let g:WhichKeyDesc_db_run = '<leader>dr Run query'
let g:WhichKeyDesc_db_tables = '<leader>dt Properties'
let g:WhichKeyDesc_db_open = '<leader>dd Database tool window'
