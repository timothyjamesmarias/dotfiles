" -*- mode: vimrc -*-
" Doom Emacs-style IdeaVim configuration
" Base: sei40kr/idea-doom-emacs
" Custom layers: LSP, database, GitHub CLI, macOS, tags, run/debug, refactor

let mapleader = " "

" ============================================================================
" Core settings
" ============================================================================
set clipboard+=unnamed
set commentary
set history
set ignorecase
set matchpairs
set multiple-cursors
set number
set relativenumber
set smartcase
set surround
set wrapscan
set visualbell
set noerrorbells
set ideajoin=true
set idearefactormode=visual
set ideavimsupport=

" evil-escape
imap jk <Esc>

" ============================================================================
" Hybrid mode (Emacs keybindings in insert/command mode)
" ============================================================================
inoremap <C-a> <Esc>I
cnoremap <C-a> <Home>
inoremap <C-b> <Left>
inoremap <C-d> <Del>
inoremap <C-e> <Esc>A
cnoremap <C-e> <End>
inoremap <C-f> <Right>
noremap <C-g> <Esc>
inoremap <C-g> <Nop>
inoremap <C-h> <BS>
inoremap <C-k> <Esc>:action EditorDeleteToLineEnd<CR>a
inoremap <A-b> <Esc>:action EditorPreviousWord<CR>i
inoremap <A-f> <Esc>:action EditorNextWord<CR>a

" ============================================================================
" General bracket mappings
" ============================================================================
" Insert newline above/below
nnoremap [<Space> O<Esc>j
vnoremap [<Space> <Esc>O<Esc>j
nnoremap ]<Space> o<Esc>k
vnoremap ]<Space> <Esc>o<Esc>k

" Error navigation
nmap [d <Action>(GotoPreviousError)
nmap ]d <Action>(GotoNextError)

" Method navigation
nmap [[ <Action>(MethodUp)
nmap ]] <Action>(MethodDown)

" Hunk navigation
nmap [c <Action>(VcsShowPrevChangeMarker)
nmap ]c <Action>(VcsShowNextChangeMarker)

" Bookmark navigation
nmap [m <Action>(GotoPreviousBookmark)
nmap ]m <Action>(GotoNextBookmark)

" Search centered
nmap n nzz
nmap N Nzz

" Fold management
nmap zc <Action>(CollapseRegion)
nmap zo <Action>(ExpandRegion)
nmap zm <Action>(CollapseAllRegions)
nmap zr <Action>(ExpandAllRegions)
nmap zC <Action>(CollapseRegionRecursively)
nmap zO <Action>(ExpandRegionRecursively)

" doom-escape-hook
nnoremap <Esc> :<C-u>nohl<CR>:<C-u>action HideAllWindows<CR><Esc>

" Semicolon for command mode
nmap ; :

" K for documentation
nmap K <Action>(QuickJavaDoc)

" ============================================================================
" Buffer/Tab navigation (C-n/C-p like centaur-tabs)
" ============================================================================
nmap <C-n> <Action>(NextTab)
nmap <C-p> <Action>(PreviousTab)

" ============================================================================
" Quick launchers (SPC prefix, no group)
" ============================================================================
map <Leader>/ <Action>(FindInPath)
map <Leader>. <Action>(SearchEverywhere)
map <Leader><CR> <Action>(Bookmarks)
map <Leader>< <Action>(Switcher)
map <Leader>` <Action>(GoToLastTab)
map <Leader>~ <Action>(JumpToLastWindow)

let g:WhichKeyDesc_search_project = '<leader>/ Search project'
let g:WhichKeyDesc_find_file = '<leader>. Find file'
let g:WhichKeyDesc_jump_to_bookmark = '<leader><CR> Jump to bookmark'
let g:WhichKeyDesc_switch_buffer = '<leader>< Switch buffer'
let g:WhichKeyDesc_last_buffer = '<leader>` Switch to last buffer'
let g:WhichKeyDesc_last_popup = '<leader>~ Toggle last popup'

" ============================================================================
" +buffer (SPC b)
" ============================================================================
let g:WhichKeyDesc_buffer = '<leader>b +buffer'
map <Leader>bb <Action>(RecentFiles)
map <Leader>bd <Action>(CloseContent)
map <Leader>bk <Action>(CloseContent)
noremap <Leader>bs :<C-u>w<CR>
map <Leader>bK <Action>(CloseAllEditors)
map <Leader>bN <Action>(NewScratchBuffer)
map <Leader>bO <Action>(CloseAllEditorsButActive)
noremap <Leader>bS :<C-u>wa<CR>

let g:WhichKeyDesc_buffer_switch = '<leader>bb Switch workspace buffer'
let g:WhichKeyDesc_buffer_kill = '<leader>bd Kill buffer'
let g:WhichKeyDesc_buffer_kill2 = '<leader>bk Kill buffer'
let g:WhichKeyDesc_buffer_save = '<leader>bs Save buffer'
let g:WhichKeyDesc_buffer_kill_all = '<leader>bK Kill all buffers'
let g:WhichKeyDesc_buffer_new = '<leader>bN New empty buffer'
let g:WhichKeyDesc_buffer_kill_others = '<leader>bO Kill other buffers'
let g:WhichKeyDesc_buffer_save_all = '<leader>bS Save all buffers'

" ============================================================================
" +code (SPC c) - Doom's code prefix
" ============================================================================
let g:WhichKeyDesc_code = '<leader>c +code'
map <Leader>ca <Action>(ShowIntentionActions)
map <Leader>cc <Action>(CompileDirty)
noremap <Leader>cd gd
nmap <Leader>cf <Action>(ReformatCode)
map <Leader>ci <Action>(GotoImplementation)
map <Leader>cj <Action>(SearchEverywhere)
map <Leader>ck <Action>(QuickJavaDoc)
map <Leader>co <Action>(OptimizeImports)
map <Leader>cr <Action>(RenameElement)
map <Leader>ct <Action>(GotoTypeDeclaration)
map <Leader>cD <Action>(ShowUsages)
map <Leader>cC <Action>(Compile)

let g:WhichKeyDesc_code_action = '<leader>ca Code action'
let g:WhichKeyDesc_code_compile = '<leader>cc Compile'
let g:WhichKeyDesc_code_definition = '<leader>cd Jump to definition'
let g:WhichKeyDesc_code_format = '<leader>cf Format buffer'
let g:WhichKeyDesc_code_impl = '<leader>ci Find implementations'
let g:WhichKeyDesc_code_symbol = '<leader>cj Jump to symbol'
let g:WhichKeyDesc_code_doc = '<leader>ck Documentation'
let g:WhichKeyDesc_code_imports = '<leader>co Optimize imports'
let g:WhichKeyDesc_code_rename = '<leader>cr Rename'
let g:WhichKeyDesc_code_type = '<leader>ct Type definition'
let g:WhichKeyDesc_code_refs = '<leader>cD Jump to references'
let g:WhichKeyDesc_code_recompile = '<leader>cC Recompile'

