map <Leader>gC <Action>(Vcs.VcsClone)
map <Leader>gF <Action>(Git.Fetch)
map <Leader>gS <Action>(Git.Add)
map <Leader>gd <Action>(Compare.SameVersion)
map <Leader>gD <Action>(Compare.LastVersion)

let g:WhichKeyDesc_git_github = "<leader>g' GitHub menu"
let g:WhichKeyDesc_git_file_actions = '<leader>g. Git file actions'
