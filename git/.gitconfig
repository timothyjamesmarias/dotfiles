[user]
	name = timothyjamesmarias
	email = timothyjamesmarias@gmail.com
[core]
	autocrlf = input
  editor = emacsclient --socket-name=doom
  pager = delta
	excludesfile = ~/.gitignore_global
[delta]
  navigate = true
  line-numbers = true
  syntax-theme = base16
  side-by-side = true
  diff-so-fancy = true
  hyperlinks = true
[merge]
  conflictstyle = diff3
