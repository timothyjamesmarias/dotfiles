{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "z (dual-role): hold 150ms = symbol layer, tap = z",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": { "key_code": "z" },
                                "to_if_held_down": [{ "set_variable": { "name": "z_symbol_layer", "value": 1 } }],
                                "to_after_key_up": [{ "set_variable": { "name": "z_symbol_layer", "value": 0 } }],
                                "to_if_alone": [{ "key_code": "z" }],
                                "parameters": {
                                    "basic.to_if_alone_timeout_milliseconds": 500,
                                    "basic.to_if_held_down_threshold_milliseconds": 100
                                }
                            }
                        ]
                    },
                    {
                        "description": "Symbol layer: right home row = parens, brackets, braces, angles",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": { "key_code": "j" },
                                "to": [{ "key_code": "9", "modifiers": ["left_shift"] }],
                                "conditions": [{ "type": "variable_if", "name": "z_symbol_layer", "value": 1 }]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "k" },
                                "to": [{ "key_code": "0", "modifiers": ["left_shift"] }],
                                "conditions": [{ "type": "variable_if", "name": "z_symbol_layer", "value": 1 }]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "l" },
                                "to": [{ "key_code": "open_bracket" }],
                                "conditions": [{ "type": "variable_if", "name": "z_symbol_layer", "value": 1 }]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "semicolon" },
                                "to": [{ "key_code": "close_bracket" }],
                                "conditions": [{ "type": "variable_if", "name": "z_symbol_layer", "value": 1 }]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "h" },
                                "to": [{ "key_code": "open_bracket", "modifiers": ["left_shift"] }],
                                "conditions": [{ "type": "variable_if", "name": "z_symbol_layer", "value": 1 }]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "quote" },
                                "to": [{ "key_code": "close_bracket", "modifiers": ["left_shift"] }],
                                "conditions": [{ "type": "variable_if", "name": "z_symbol_layer", "value": 1 }]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "u" },
                                "to": [{ "key_code": "comma", "modifiers": ["left_shift"] }],
                                "conditions": [{ "type": "variable_if", "name": "z_symbol_layer", "value": 1 }]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "i" },
                                "to": [{ "key_code": "period", "modifiers": ["left_shift"] }],
                                "conditions": [{ "type": "variable_if", "name": "z_symbol_layer", "value": 1 }]
                            }
                        ]
                    },
                    {
                        "description": "C-w = delete word backward (outside Emacs/terminals)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": { "key_code": "w", "modifiers": { "mandatory": ["control"] } },
                                "to": [{ "key_code": "delete_or_backspace", "modifiers": ["left_option"] }],
                                "conditions": [
                                    {
                                        "type": "frontmost_application_unless",
                                        "bundle_identifiers": [
                                            "^org\\.gnu\\.Emacs",
                                            "^io\\.alacritty",
                                            "^com\\.apple\\.Terminal",
                                            "^com\\.mitchellh\\.ghostty",
                                            "^net\\.kovidgoyal\\.kitty"
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            "name": "Default",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}
